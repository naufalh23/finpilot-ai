// FinPilot AI Lite — Prisma schema
// Covers the full PRD v0.1 domain. UI is built in phases, but the data model
// lands in one migration so later phases don't reshape the database.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Identity
//
// Authentication lives in Supabase Auth (Google OAuth), which owns its own
// Postgres in the Supabase project. This table is the application-side mirror:
// `id` is the Supabase `auth.users.id` UUID, so there is no cross-database
// foreign key — the id is simply carried over on first sign-in.
// ---------------------------------------------------------------------------

model User {
  id            String    @id
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  settings      UserSettings?
  wallets       Wallet[]
  categories    Category[]
  transactions  Transaction[]
  budgets       Budget[]
  recurrings    RecurringTransaction[]
  subscriptions Subscription[]
  creditCards   CreditCard[]
  loans         Loan[]
  investments   Investment[]
  insights      AiInsight[]
  chatSessions  ChatSession[]
  notifications Notification[]
}

// ---------------------------------------------------------------------------
// Settings
// ---------------------------------------------------------------------------

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

model UserSettings {
  id            String          @id @default(cuid())
  userId        String          @unique
  currency      String          @default("IDR")
  locale        String          @default("id-ID")
  timezone      String          @default("Asia/Jakarta")
  theme         ThemePreference @default(DARK)
  // Day of month the financial cycle starts (1 = calendar month).
  monthStartDay Int             @default(1)
  hideAmounts   Boolean         @default(false)
  notifyBudget  Boolean         @default(true)
  notifyBills   Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Wallet
// ---------------------------------------------------------------------------

enum WalletType {
  CASH
  BANK
  EWALLET
  CREDIT_CARD
  INVESTMENT
}

model Wallet {
  id             String     @id @default(cuid())
  userId         String
  name           String
  type           WalletType @default(CASH)
  // Opening balance. The live balance is opening + sum(transactions).
  openingBalance Decimal    @default(0) @db.Decimal(18, 2)
  currency       String     @default("IDR")
  color          String?
  icon           String?
  institution    String?
  isArchived     Boolean    @default(false)
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]          @relation("WalletTransactions")
  transfersIn   Transaction[]          @relation("WalletTransfersIn")
  recurrings    RecurringTransaction[]
  subscriptions Subscription[]
  creditCard    CreditCard?
  loans         Loan[]

  @@index([userId, isArchived])
}

// ---------------------------------------------------------------------------
// Category
// ---------------------------------------------------------------------------

enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id         String       @id @default(cuid())
  userId     String
  name       String
  type       CategoryType
  icon       String?
  color      String?
  isDefault  Boolean      @default(false)
  isArchived Boolean      @default(false)
  parentId   String?
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent        Category?              @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[]             @relation("CategoryChildren")
  transactions  Transaction[]
  budgets       Budget[]
  recurrings    RecurringTransaction[]
  subscriptions Subscription[]

  @@unique([userId, name, type])
  @@index([userId, type])
}

// ---------------------------------------------------------------------------
// Transaction
// ---------------------------------------------------------------------------

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
}

model Transaction {
  id     String            @id @default(cuid())
  userId String
  type   TransactionType
  status TransactionStatus @default(COMPLETED)
  date   DateTime
  amount Decimal           @db.Decimal(18, 2)

  currency   String  @default("IDR")
  walletId   String
  // Destination wallet, only for TRANSFER.
  toWalletId String?
  categoryId String?
  merchant   String?
  notes      String?

  // Set when the row was drafted by Gemini (receipt OCR / chat / auto-category).
  aiGenerated    Boolean  @default(false)
  aiConfidence   Float?
  recurringId    String?
  subscriptionId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet                @relation("WalletTransactions", fields: [walletId], references: [id], onDelete: Cascade)
  toWallet     Wallet?               @relation("WalletTransfersIn", fields: [toWalletId], references: [id], onDelete: SetNull)
  category     Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurring    RecurringTransaction? @relation(fields: [recurringId], references: [id], onDelete: SetNull)
  subscription Subscription?         @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  attachments  Attachment[]

  @@index([userId, date])
  @@index([userId, type, date])
  @@index([walletId])
  @@index([categoryId])
}

model Attachment {
  id            String   @id @default(cuid())
  transactionId String
  url           String
  storagePath   String?
  mimeType      String?
  size          Int?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

// ---------------------------------------------------------------------------
// Budget
// ---------------------------------------------------------------------------

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  // First day of the budget month, normalised to UTC midnight.
  period     DateTime
  amount     Decimal  @db.Decimal(18, 2)
  // Percentage at which a warning is raised.
  alertAt    Int      @default(90)
  rollover   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, period])
  @@index([userId, period])
}

// ---------------------------------------------------------------------------
// Recurring transaction
// ---------------------------------------------------------------------------

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model RecurringTransaction {
  id         String          @id @default(cuid())
  userId     String
  name       String
  type       TransactionType
  amount     Decimal         @db.Decimal(18, 2)
  walletId   String
  categoryId String?
  frequency  Frequency
  // Every N periods, e.g. interval 2 + WEEKLY = fortnightly.
  interval   Int             @default(1)
  startDate  DateTime
  endDate    DateTime?
  nextRunAt  DateTime
  lastRunAt  DateTime?
  autoCreate Boolean         @default(true)
  isActive   Boolean         @default(true)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId, isActive, nextRunAt])
}

// ---------------------------------------------------------------------------
// Subscription manager
// ---------------------------------------------------------------------------

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  name            String
  price           Decimal            @db.Decimal(18, 2)
  currency        String             @default("IDR")
  billingCycle    Frequency          @default(MONTHLY)
  nextBillingDate DateTime
  autoRenew       Boolean            @default(true)
  reminderDays    Int                @default(3)
  status          SubscriptionStatus @default(ACTIVE)
  walletId        String?
  categoryId      String?
  icon            String?
  color           String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet?       @relation(fields: [walletId], references: [id], onDelete: SetNull)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId, status, nextBillingDate])
}

// ---------------------------------------------------------------------------
// Credit card
// ---------------------------------------------------------------------------

model CreditCard {
  id String @id @default(cuid())

  userId       String
  // Each credit card is backed by a WalletType.CREDIT_CARD wallet.
  walletId     String   @unique
  issuer       String
  last4        String?
  creditLimit  Decimal  @db.Decimal(18, 2)
  // Day of month, 1-31.
  billingDay   Int
  dueDay       Int
  reminderDays Int      @default(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Loan
// ---------------------------------------------------------------------------

enum LoanType {
  PERSONAL
  BANK
  VEHICLE
  MORTGAGE
  OTHER
}

model Loan {
  id               String    @id @default(cuid())
  userId           String
  name             String
  type             LoanType  @default(PERSONAL)
  lender           String?
  principal        Decimal   @db.Decimal(18, 2)
  remainingBalance Decimal   @db.Decimal(18, 2)
  installment      Decimal   @db.Decimal(18, 2)
  interestRate     Float?
  tenorMonths      Int?
  dueDay           Int
  startDate        DateTime
  endDate          DateTime?
  walletId         String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet? @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
}

// ---------------------------------------------------------------------------
// Investment (manual tracking in v0.1)
// ---------------------------------------------------------------------------

enum InvestmentType {
  STOCK
  CRYPTO
  GOLD
  MUTUAL_FUND
  ETF
  OTHER
}

model Investment {
  id           String         @id @default(cuid())
  userId       String
  name         String
  symbol       String?
  type         InvestmentType @default(STOCK)
  quantity     Decimal        @db.Decimal(24, 8)
  buyPrice     Decimal        @db.Decimal(24, 8)
  // Updated by hand in v0.1 — no price feed yet.
  currentPrice Decimal        @db.Decimal(24, 8)
  currency     String         @default("IDR")
  buyDate      DateTime
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

// ---------------------------------------------------------------------------
// AI
// ---------------------------------------------------------------------------

enum InsightSeverity {
  INFO
  SUCCESS
  WARNING
  DANGER
}

model AiInsight {
  id          String          @id @default(cuid())
  userId      String
  // e.g. "spending_spike", "budget_warning", "saving_rate", "monthly_review"
  kind        String
  title       String
  body        String
  severity    InsightSeverity @default(INFO)
  periodStart DateTime?
  periodEnd   DateTime?
  // Supporting numbers used to render the card without recomputing.
  meta        Json?
  dismissedAt DateTime?
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissedAt, createdAt])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

enum ChatRole {
  USER
  ASSISTANT
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      ChatRole
  content   String   @db.Text
  // Aggregates the model was given, kept for debugging answers.
  context   Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------

enum NotificationKind {
  BUDGET
  SUBSCRIPTION
  CREDIT_CARD
  LOAN
  RECURRING
  INSIGHT
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  kind         NotificationKind
  title        String
  body         String
  link         String?
  readAt       DateTime?
  // When the reminder becomes relevant; used to avoid firing early.
  scheduledFor DateTime?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}
